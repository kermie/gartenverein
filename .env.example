# Datenbank
POSTGRES_DB=gartenverein
POSTGRES_USER=gartenverein
POSTGRES_PASSWORD=sicheres-passwort-hier

# Anwendung
SECRET_KEY=bitte-einen-langen-zufaelligen-string-hier
ENVIRONMENT=development

# E-Mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=email-passwort
SMTP_FROM=verein@example.com
SMTP_TLS=true

# Container-Benutzer (verhindert root-Dateien auf dem Host bei gemounteten
# Volumes, z.B. migrations/). Mit "id -u" / "id -g" auf deinem System ermitteln.
UID=1000
GID=1000
